{
  "name": "social-analytics-challenge",
  "version": "0.0.1",
  "type": "module",
  "description": "",
  "main": "server.ts",
 "scripts": {
    "dev": "tsx watch --env-file=.env server.ts",
    "pretest": "tsx --env-file=.env tests/setup-db.ts",
    "test": "node --env-file=.env.test node_modules/vitest/vitest.mjs",
    "db:push": "drizzle-kit push",
    "db:seed": "tsx --env-file=.env scripts/seed.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate:up": "drizzle-kit migrate:up",
    "db:migrate:down": "drizzle-kit migrate:down",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "tsc --noEmit"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.30.0",
  "dependencies": {
    "@fastify/static": "^9.0.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "csv-parse": "^6.1.0",
    "drizzle-orm": "^0.45.1",
    "fastify": "^5.7.4",
    "fastify-type-provider-zod": "^6.1.0",
    "postgres": "^3.4.8",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.3.0",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "drizzle-kit": "^0.31.9",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
